# LoomSpace backend environment
# Copy to .env and fill in real values before starting the stack.

# REQUIRED: Random secret for encrypting API keys stored in the database.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DATA_SECRET=change-me

# REQUIRED: Secret for signing JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me

# PostgreSQL connection string.
# With docker-compose the hostname is the service name "db".
# For an external instance, replace host/port/credentials accordingly.
DATABASE_URL=postgresql+asyncpg://loomspace:loomspace@db:5432/loomspace

# CORS origins allowed to call the backend (JSON array of strings).
# The default in config.py covers the Vite dev server ports.
# CORS_ORIGINS=["http://localhost:5174","http://localhost:5173"]

# JWT settings — defaults are fine for development.
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=10080
